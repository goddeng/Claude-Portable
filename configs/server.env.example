# License Server Configuration
# Copy to server.env and fill in your values

# Encryption key for credential transmission (change this!)
ENCRYPT_KEY=your-secret-key-here

# Internal network prefixes (comma-separated, no spaces)
# Clients from these IPs get auto-activated without code
INTERNAL_PREFIXES=192.168.1.,10.0.0.,127.0.0.1

# Claude credentials paths
CLAUDE_CREDS=~/.claude/.credentials.json
CLAUDE_STATE=~/.claude.json

# SS proxy config path
SS_CONFIG=/path/to/ss-config.json
