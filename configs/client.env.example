# Client build-time configuration
# Copy to client.env and fill in your value
# This is injected into the package at build time
#
# Since v1.0.5: client no longer embeds server address or symmetric keys.
# The ONLY build-time config is the TLS SPKI pin (public key fingerprint),
# which is NOT a secret — it's just how the client verifies it connects to
# the real server (certificate pinning).
#
# How to compute:
#   openssl x509 -in server/tls/cert.pem -pubkey -noout \
#     | openssl pkey -pubin -outform DER \
#     | openssl dgst -sha256 -binary | base64
#
# Example (random):
#   SPKI_PIN=AbCdEf1234567890+xyz/BaseSHA256FingerprintEncodedInBase64=

SPKI_PIN=REPLACE_WITH_YOUR_SPKI_PIN_BASE64
