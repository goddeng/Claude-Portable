# Client build-time configuration
# Copy to client.env and fill in your values
# These are injected into the package at build time

# Internal server addresses (comma-separated)
# Clients silently try these first - if reachable, auto-activate without code
INTERNAL_SERVERS=http://192.168.1.100:9099,http://10.0.0.100:9099

# Encryption key - must match server's ENCRYPT_KEY
ENCRYPT_KEY=your-secret-key-here
